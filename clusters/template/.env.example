# =============================================================================
# AgentX Cluster Configuration
# =============================================================================
# This file is the source `task cluster:new CLUSTER=<name>` copies into
# clusters/<name>/.env. A cluster is the production deployment unit — fill in
# the required values, then bring it up with `task cluster:up CLUSTER=<name>`.
#
# For a public-facing cluster fronted by Nginx + Cloudflare Tunnel, scaffold
# the gateway files at the same time:
#   task cluster:new CLUSTER=<name> GATEWAY=1
# Or add them to an existing cluster with:
#   task cluster:gateway:enable CLUSTER=<name>

# -----------------------------------------------------------------------------
# Cluster Identity (REQUIRED)
# -----------------------------------------------------------------------------

# Unique name for this cluster (used in container names, logs, health endpoint).
# Should match the directory name under clusters/.
AGENTX_CLUSTER_NAME=

# Per-cluster data directory (bind-mounted by docker-compose).
AGENTX_DATA_DIR=./clusters/<name>/data

# Port configuration — change these per cluster to avoid conflicts when
# running multiple clusters on the same host.
API_PORT=12319
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
POSTGRES_PORT=5432
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Django Settings (REQUIRED)
# -----------------------------------------------------------------------------

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Production clusters should run with debug off.
DJANGO_DEBUG=false

# Comma-separated allowed hosts. AGENTX_PUBLIC_HOST below is appended
# automatically when set.
DJANGO_ALLOWED_HOSTS=

# Public hostname for clusters fronted by the gateway (Nginx + Cloudflare
# Tunnel). Setting this also extends ALLOWED_HOSTS, CORS_ALLOWED_ORIGINS, and
# CSRF_TRUSTED_ORIGINS so the three lists can't drift. Leave blank for
# private/LAN clusters.
# Example: agentx.yourdomain.com
AGENTX_PUBLIC_HOST=

# Shared-secret header required by the Nginx gateway on every request.
# Generate with: openssl rand -hex 32
# Only required when the gateway is enabled for this cluster.
AGENTX_GATEWAY_TOKEN=

# -----------------------------------------------------------------------------
# Database Credentials (REQUIRED — change from defaults)
# -----------------------------------------------------------------------------

NEO4J_PASSWORD=
POSTGRES_USER=agent
POSTGRES_PASSWORD=
POSTGRES_DB=agent_memory

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Required for any internet-exposed cluster. Safe to leave on for LAN-only
# clusters too.
AGENTX_AUTH_ENABLED=true
AGENTX_SESSION_TTL=86400

# -----------------------------------------------------------------------------
# CORS / CSRF (only needed when AGENTX_PUBLIC_HOST is set)
# -----------------------------------------------------------------------------

CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# -----------------------------------------------------------------------------
# LLM Provider API Keys (at least one required)
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
AI_GATEWAY_API_KEY=

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------

# "local" (BAAI/bge-m3) or "openai"
EMBEDDING_PROVIDER=local

# -----------------------------------------------------------------------------
# Quick Reference
# -----------------------------------------------------------------------------
#
# Private/LAN cluster (replaces what used to be called "mock production"):
#   task cluster:new CLUSTER=local-prod
#   # edit clusters/local-prod/.env (debug=false, auth on, secrets)
#   task cluster:up CLUSTER=local-prod
#   task cluster:auth:setup CLUSTER=local-prod
#
# Public cluster with Nginx + Cloudflare Tunnel:
#   task cluster:new CLUSTER=prod GATEWAY=1
#   # edit clusters/prod/.env (set AGENTX_PUBLIC_HOST, AGENTX_GATEWAY_TOKEN)
#   # edit clusters/prod/cloudflared/config.yml — paste tunnel id
#   # drop clusters/prod/cloudflared/credentials.json into place
#   task cluster:up CLUSTER=prod
#
# Smoke test (gateway):
#   curl -I https://$AGENTX_PUBLIC_HOST/api/health  # → 401
#   curl -I -H "AgentX-Gateway-Token: $AGENTX_GATEWAY_TOKEN" \
#        https://$AGENTX_PUBLIC_HOST/api/health      # → 200
