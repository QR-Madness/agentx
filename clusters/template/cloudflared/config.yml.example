# Cloudflare *named* tunnel ingress for an AgentX gateway deployment.
# Lives at ${AGENTX_GATEWAY_DIR}/cloudflared/config.yml (local clusters:
# clusters/<name>/cloudflared/config.yml).
#
# One-time setup on the host before bringing the stack up:
#   1. cloudflared tunnel login
#   2. cloudflared tunnel create agentx-<name>
#      → writes credentials to ~/.cloudflared/<tunnel-id>.json
#   3. Copy that file to <gateway-dir>/cloudflared/credentials.json
#   4. cloudflared tunnel route dns agentx-<name> <public-host>
#   5. Replace <tunnel-id> and <public-host> below to match
#      AGENTX_PUBLIC_HOST in your .env.
#
# Then: task cluster:up CLUSTER=<name> (local clusters), or layer
# docker-compose.gateway.yml + docker-compose.tunnel.named.yml (isolated).

tunnel: <tunnel-id>
credentials-file: /etc/cloudflared/credentials.json

# Reduce noise; bump to "info" or "debug" while diagnosing.
loglevel: warn

ingress:
  # Public hostname → nginx gateway on the compose network.
  - hostname: <public-host>
    service: http://nginx:80
    originRequest:
      httpHostHeader: <public-host>
      connectTimeout: 10s
      # Disable Happy Eyeballs (IPv4/IPv6 connection racing) — the origin is
      # a single compose-network hostname, so racing address families only
      # adds noise. Note this is NOT a streaming/idle timeout: long SSE
      # responses are kept alive by nginx's proxy_buffering off +
      # proxy_read_timeout 600s (see nginx.conf), and cloudflared does not
      # cut chunked responses that are still transferring.
      noHappyEyeballs: true

  # Catch-all: anything not matching the hostname above gets a flat 404
  # at the tunnel, never touches nginx.
  - service: http_status:404
