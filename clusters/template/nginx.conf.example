# clusters/<name>/nginx.conf
#
# Cluster gateway between Cloudflare Tunnel and the AgentX API. Mounted at
# /etc/nginx/templates/default.conf.template inside the nginx:alpine
# container, which runs envsubst over it at startup and emits the final
# config to /etc/nginx/conf.d/default.conf.
#
# Substituted variables (set in docker-compose.cluster.yml):
#   ${AGENTX_GATEWAY_TOKEN} - shared secret required on every request
#   ${AGENTX_API_HOST}      - upstream Django host (typically: api)
#   ${AGENTX_API_PORT}      - upstream Django port (typically: 12319)
#
# All other ${...} references in this file (nginx variables like
# $http_x_forwarded_for) are NOT environment variables. We keep nginx
# variables in the bare $name form (no braces) so the template processor
# leaves them alone.

# Rate limit zone: 10 req/s per client IP, 10MB memory (~160k IPs).
# Cloudflare Tunnel forwards the original client IP via CF-Connecting-IP;
# we trust it because the only reachable ingress is the tunnel itself.
limit_req_zone $http_cf_connecting_ip zone=agentx_gateway:10m rate=10r/s;

# Constant-string comparison for the gateway token. Using `map` rather
# than `if` inside the server block keeps us out of nginx's "if is evil"
# territory — map is evaluated lazily and only when $gateway_authorized
# is referenced.
map $http_agentx_gateway_token $gateway_authorized {
    default                          0;
    "${AGENTX_GATEWAY_TOKEN}"        1;
}

server {
    listen 80 default_server;
    server_name _;

    client_max_body_size 10m;

    limit_req zone=agentx_gateway burst=20 nodelay;
    limit_req_status 429;

    if ($gateway_authorized = 0) {
        return 401;
    }

    # Health probe for the tunnel — Cloudflared can hit this without the
    # token to verify the gateway itself is alive.
    location = /__gateway_health {
        access_log off;
        add_header Content-Type text/plain;
        return 200 "ok\n";
    }

    location / {
        proxy_pass http://${AGENTX_API_HOST}:${AGENTX_API_PORT};
        proxy_http_version 1.1;

        # Strip the token before forwarding so it never lands in Django
        # logs or any downstream proxy state.
        proxy_set_header AgentX-Gateway-Token "";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $http_cf_connecting_ip;
        proxy_set_header X-Forwarded-For $http_cf_connecting_ip;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;

        # SSE / streaming endpoints (e.g., /api/agent/chat/stream) need
        # buffering disabled so chunks reach the client as they're produced.
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}
