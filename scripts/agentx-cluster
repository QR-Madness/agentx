#!/usr/bin/env bash
#
# agentx-cluster - Multi-cluster launcher for AgentX
#
# Usage:
#   agentx-cluster <cluster-dir> <command> [args...]
#
# Examples:
#   agentx-cluster ~/clusters/production up -d
#   agentx-cluster ~/clusters/staging logs -f api
#   agentx-cluster ~/clusters/dev ps
#
# The cluster directory must contain:
#   - .env.production (cluster-specific configuration)
#
# The script will:
#   1. Load environment from <cluster-dir>/.env.production
#   2. Set AGENTX_DATA_DIR to <cluster-dir>/data
#   3. Run docker-compose with the AgentX source docker-compose.yml

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SOURCE_DIR="$(dirname "$SCRIPT_DIR")"

usage() {
    echo "agentx-cluster - Multi-cluster launcher for AgentX"
    echo ""
    echo "Usage: agentx-cluster <cluster-dir> <command> [args...]"
    echo ""
    echo "Commands (passed to docker compose):"
    echo "  up [-d]       Start cluster services"
    echo "  down          Stop cluster services"
    echo "  logs [-f]     View logs"
    echo "  ps            Show status"
    echo "  restart       Restart services"
    echo "  exec          Execute command in container"
    echo ""
    echo "Examples:"
    echo "  agentx-cluster ~/clusters/prod up -d"
    echo "  agentx-cluster ~/clusters/staging logs -f api"
    echo "  agentx-cluster ~/clusters/dev exec api uv run manage.py setup_auth"
    echo ""
    echo "Cluster directory structure:"
    echo "  <cluster-dir>/"
    echo "    .env.production    # Cluster configuration"
    echo "    data/              # Database storage (auto-created)"
    exit 1
}

# Show usage if no args
[[ $# -lt 2 ]] && usage

CLUSTER_DIR="$1"
shift

# Resolve to absolute path
CLUSTER_DIR="$(cd "$CLUSTER_DIR" 2>/dev/null && pwd)" || {
    echo "Error: Cluster directory not found: $1"
    exit 1
}

ENV_FILE="$CLUSTER_DIR/.env.production"
if [[ ! -f "$ENV_FILE" ]]; then
    echo "Error: Missing .env.production in $CLUSTER_DIR"
    echo ""
    echo "Create it with at least:"
    echo "  AGENTX_CLUSTER_NAME=your-cluster-name"
    echo "  API_PORT=12319"
    echo "  NEO4J_HTTP_PORT=7474"
    echo "  NEO4J_BOLT_PORT=7687"
    echo "  POSTGRES_PORT=5432"
    echo "  REDIS_PORT=6379"
    echo ""
    echo "Or copy from the template:"
    echo "  cp $SOURCE_DIR/.env.production.example $ENV_FILE"
    exit 1
fi

# Export cluster data directory
export AGENTX_DATA_DIR="$CLUSTER_DIR/data"

# Ensure data directories exist
mkdir -p "$AGENTX_DATA_DIR"/{neo4j/{data,logs,plugins},postgres,redis}

echo "Cluster: $CLUSTER_DIR"
echo "Data:    $AGENTX_DATA_DIR"
echo ""

# Run docker compose with source compose file and cluster env
cd "$SOURCE_DIR"
docker compose \
    -f "$SOURCE_DIR/docker-compose.yml" \
    --env-file "$ENV_FILE" \
    --profile production \
    "$@"
