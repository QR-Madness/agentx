# AgentX Environment Configuration
# Copy this file to .env and fill in your values
#
# AgentX is OFFLINE-FIRST: LM Studio is the baseline.
# Cloud providers (OpenAI, Anthropic, OpenRouter) are optional for offloading.

# =============================================================================
# Default Model Settings (Offline-First)
# =============================================================================

# Default model for reasoning/chat (uses local models by default)
# Examples: llama-3.2-1b-instruct, mistral-nemo-instruct, claude-3-5-sonnet-latest
DEFAULT_MODEL=llama-3.2-1b-instruct

# =============================================================================
# Local Model Settings (Primary)
# =============================================================================

# LM Studio server URL (preferred for local models - OpenAI-compatible API)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_TIMEOUT=600

# Ollama server URL (alternative to LM Studio)
# OLLAMA_BASE_URL=http://localhost:11434

# HuggingFace token (optional, for gated models)
HF_TOKEN=

# =============================================================================
# Cloud Providers (Optional - for offloading)
# =============================================================================

# Anthropic (for Claude models)
ANTHROPIC_API_KEY=

# OpenAI (for GPT models)
OPENAI_API_KEY=

# OpenRouter (cloud aggregator - 100+ models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional attribution headers for OpenRouter leaderboards
# OPENROUTER_SITE_URL=
# OPENROUTER_APP_NAME=AgentX

# Vercel AI Gateway (cloud aggregator - 100+ models, high availability)
# Get your key at: https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# =============================================================================
# MCP Connectors (OAuth)
# =============================================================================

# Google Drive connector (Connectors & Tools → catalog) — Google requires a
# pre-registered OAuth app (no dynamic registration). Create it in Google
# Cloud console (enable the Drive API + Drive MCP API, consent screen with
# the two Drive scopes, OAuth client ID of type "Web application") and put
# the credentials here; the catalog's quick-add references them as ${VAR} so
# they never land in mcp_servers.json.
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=

# OAuth redirect URI advertised to providers. Default:
#   http://localhost:12319/api/mcp/oauth/callback
# For a gateway/tunnel cluster set it to the cluster's public host, e.g.
#   https://<cluster-host>/api/mcp/oauth/callback
# and register that exact URI on the OAuth app. ONE Google app can serve ALL
# clusters: add each cluster's callback URI to the same app (Google allows
# many), reuse the same client id/secret in every cluster's .env, and DNS
# routes each consent redirect back to the right cluster. The gateway lets
# this exact path through tokenless (see clusters/template/nginx.conf.example
# — the browser redirect can't carry the gateway token).
# AGENTX_OAUTH_REDIRECT_URL=

# =============================================================================
# Database Credentials
# =============================================================================

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# PostgreSQL (with pgvector)
POSTGRES_USER=agent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agent_memory
POSTGRES_URI=postgresql://agent:changeme@localhost:5432/agent_memory

# Redis Cache
REDIS_URI=redis://localhost:6379

# =============================================================================
# Embedding Configuration
# =============================================================================

# Embedding provider: "openai" or "local"
EMBEDDING_PROVIDER=local

# OpenAI embedding model (if using OpenAI)
EMBEDDING_MODEL=text-embedding-3-small

# Local embedding model (if using local)
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3

# Embedding request queue (serializes embed calls so the thread-unsafe local model
# and rate-limited remote provider can't collide; identical queries are cached).
# Defaults below are sensible — override only to tune throughput.
# EMBEDDING_QUEUE_ENABLED=true
# EMBEDDING_BATCH_MAX_SIZE=32
# EMBEDDING_CACHE_ENABLED=true
# EMBEDDING_CACHE_TTL_SECONDS=900

# =============================================================================
# Compute Device (GPU/CPU)
# =============================================================================

# Device for on-device models (embeddings + NLLB-200 translation):
#   auto    -> CUDA when available, else CPU (default)
#   cpu     -> force CPU
#   cuda    -> force GPU (falls back to CPU if unavailable)
#   cuda:0  -> a specific GPU index
# On Windows the default PyPI torch wheel is CPU-only — install the CUDA build to
# use a GPU (see docs: Getting Started > Windows Setup, Development > GPU Acceleration).
AGENTX_DEVICE=auto

# =============================================================================
# Application Settings
# =============================================================================

# Django secret key (generate a new one for production)
# Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Debug mode (set to false in production)
DJANGO_DEBUG=true

# Allowed hosts (comma-separated, defaults to localhost,127.0.0.1)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# API server port
API_PORT=12319

# Debug logging for LLM requests (1 to enable, 0 to disable)
DEBUG_LOG_LLM_REQUESTS=0
# When DEBUG_LOG_LLM_REQUESTS is enabled, replace full tool schemas with a compact summary (1 to enable)
COMPRESS_TOOL_OUTPUTS_IN_LLM_LOGS=0

# =============================================================================
# Authentication (Phase 17)
# =============================================================================

# Enable authentication (requires password setup via: task auth:setup).
# NOTE: the built-in default (no env at all) is now auth ON — this dev
# template opts out explicitly for local hacking.
AGENTX_AUTH_ENABLED=false

# Session TTL in seconds (default: 24 hours)
AGENTX_SESSION_TTL=86400

# --- Container boot (docker image only; no effect on `task dev`) ------------
# Self-initialize database schemas on container boot (single-process
# bootstrap; warm boots verify version stamps in seconds).
AGENTX_AUTO_INIT=true
# First boot only: reap the embedding-warmup process this many seconds after
# it reports success (its model-download threads never exit on their own).
AGENTX_INIT_EXIT_GRACE=15

# Trust X-Forwarded-For for client-IP attribution. Enable ONLY behind a
# trusted proxy that overwrites the header (the Nginx gateway does). Leave
# false when the API is reached directly — a spoofed XFF header could
# otherwise fake any client IP, including 127.0.0.1.
AGENTX_TRUST_PROXY=false

# =============================================================================
# Multi-Cluster Deployment (Phase 17.4)
# =============================================================================
# Clusters are managed via the clusters/ directory.
# Create: task cluster:new CLUSTER=<name>
# Start:  task cluster:up CLUSTER=<name>
# List:   task cluster:list
# See .env.production.example for full production setup.

# Cluster identity (used in container names, logs, and health endpoint)
AGENTX_CLUSTER_NAME=default

# Data directory (default: ./data, set to ./clusters/<name>/data for clusters)
# AGENTX_DATA_DIR=./data

# Port configuration (change for multi-cluster on same host)
# API_PORT=12319
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687
# POSTGRES_PORT=5432
# REDIS_PORT=6379

# =============================================================================
# Security Settings
# =============================================================================

# CORS allowed origins (comma-separated, defaults to localhost:1420)
# Set to specific origins in production
# CORS_ALLOWED_ORIGINS=http://localhost:1420,tauri://localhost

# CSRF trusted origins (comma-separated)
# CSRF_TRUSTED_ORIGINS=http://localhost:1420,tauri://localhost

# Input size limits
AGENTX_MAX_TEXT_LENGTH=100000
AGENTX_MAX_CHAT_LENGTH=10000

# Rate limiting (not enforced by default)
AGENTX_RATE_LIMIT_ENABLED=false
AGENTX_RATE_LIMIT_DEFAULT=100/m

# =============================================================================
# Client Settings
# =============================================================================

# API URL for the Tauri client (Vite env var)
VITE_API_URL=http://localhost:12319/api

# =============================================================================
# MCP Tool API Keys (Optional)
# =============================================================================

# Context7 MCP server (documentation lookup)
# CONTEXT_SEVEN_API_KEY=

# Web search — internal `web_search` tool (Tavily primary, Brave REST fallback).
# Keys can also be set in the UI (Settings → Web Search); env vars are the fallback.
# TAVILY_API_KEY=
# BRAVE_API_KEY=

# =============================================================================
# Logging (logging_kit) — all decorations ON by default
# =============================================================================

# Master switch for color/category/run-tag console + banner + LLM cards.
# Set to false to restore plain stdlib output (CI / journald / file capture).
# AGENTX_LOG_DECORATIONS=true

# ASCII startup banner + status table (defaults to follow AGENTX_LOG_DECORATIONS).
# AGENTX_LOG_BANNER=true

# LLM request logging: off | summary | full. Defaults to summary when decorations
# are on, off otherwise. Legacy DEBUG_LOG_LLM_REQUESTS=1 maps to "full".
# AGENTX_LLM_LOG_LEVEL=summary

# Console format: pretty (rich) or json (newline-delimited, for log aggregators).
# AGENTX_LOG_FORMAT=pretty

# Force ANSI color even on a non-TTY (Docker/journald).
# AGENTX_LOG_FORCE_COLOR=false

# Log API + in-memory ring buffer that backs the client Log panel.
# Auth-gated automatically when AGENTX_AUTH_ENABLED is set.
# AGENTX_LOG_API_ENABLED=true
# AGENTX_LOG_RING_SIZE=2000

# Compressed on-disk archive (data/logs/agentx.log[.N.gz]).
# AGENTX_LOG_ARCHIVE_ENABLED=true
# AGENTX_LOG_ARCHIVE_MAX_MB=10
# AGENTX_LOG_ARCHIVE_BACKUPS=10
