{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "cwd": "client",
      "port": 1420
    },
    {
      "name": "api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "agentx_api.asgi:application", "--host", "127.0.0.1", "--port", "12319"],
      "cwd": "api",
      "port": 12319
    },
    {
      "name": "docs",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "cwd": "docs-site",
      "port": 4321
    },
    {
      "name": "docs-preview",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "preview", "--", "--port", "4331"],
      "cwd": "docs-site",
      "port": 4331
    }
  ]
}
