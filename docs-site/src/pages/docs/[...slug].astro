---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { labelForSlug } from '../../config/nav';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries.map((entry) => {
    // The glob loader's `id` is the file path without extension (e.g. "features/chat").
    // The root index becomes /docs (an undefined rest param).
    const isHome = entry.id === 'index' || entry.id === '';
    return {
      params: { slug: isHome ? undefined : entry.id },
      props: { entry, docSlug: isHome ? '' : entry.id },
    };
  });
}

const { entry, docSlug } = Astro.props;
const { Content, headings } = await render(entry);

const title =
  labelForSlug(docSlug) ?? headings.find((h) => h.depth === 1)?.text ?? entry.id;
const description = entry.data.description;
---

<DocsLayout title={title} description={description} currentSlug={docSlug} headings={headings}>
  <Content />
</DocsLayout>
