---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <main class="mx-auto max-w-(--layout-content-max) px-4 py-24 text-center">
    <p class="text-sm font-semibold text-accent">404</p>
    <h1 class="mt-2 text-2xl font-semibold text-text">Page not found</h1>
    <p class="mt-3 text-text-muted">The page you’re looking for doesn’t exist.</p>
    <p class="mt-6"><a href="/docs" class="text-accent hover:text-accent-hover">Back to docs →</a></p>
  </main>
</BaseLayout>
