---
// WebMCP — expose one real, honest tool (docs search) to AI agents whose browser
// supports the emerging WebMCP API. Pure progressive enhancement: it silently no-ops
// where the API is absent (nearly every browser today). The tool is backed by the same
// Pagefind index the ⌘K search uses, so it only ever returns real documentation hits —
// and only in the production build (Pagefind is generated by `pagefind --site dist`).
//
// The spec is still settling on a spelling, so we feature-detect both the
// `navigator.modelContext.provideContext({ tools })` form (what discovery scanners look
// for) and the `registerTool(tool)` form, and never let registration throw.
---

<script>
  type PagefindData = { url: string; excerpt: string; meta?: { title?: string } };
  type Pagefind = {
    search: (q: string) => Promise<{ results: { data: () => Promise<PagefindData> }[] }>;
    init?: () => void;
  };

  type ToolResult = { content: { type: 'text'; text: string }[] };
  type ToolDef = {
    name: string;
    description: string;
    inputSchema: Record<string, unknown>;
    execute: (args: { query?: string }) => Promise<ToolResult>;
  };
  type ModelContext = {
    provideContext?: (ctx: { tools: ToolDef[] }) => unknown;
    registerTool?: (tool: ToolDef) => unknown;
  };

  const mc: ModelContext | undefined =
    (navigator as unknown as { modelContext?: ModelContext }).modelContext ??
    (document as unknown as { modelContext?: ModelContext }).modelContext;

  if (mc && (mc.provideContext || mc.registerTool)) {
    let pagefind: Pagefind | null = null;
    let loadError = false;

    async function ensurePagefind(): Promise<Pagefind | null> {
      if (pagefind || loadError) return pagefind;
      try {
        // Absolute runtime path — kept out of Vite's static analysis (matches Search.astro).
        const path = '/pagefind/pagefind.js';
        const mod = (await import(/* @vite-ignore */ path)) as Pagefind;
        mod.init?.();
        pagefind = mod;
      } catch {
        loadError = true;
      }
      return pagefind;
    }

    const searchDocs: ToolDef = {
      name: 'search_docs',
      description:
        'Search the AgentX documentation and return the most relevant pages (title, URL, excerpt). ' +
        'AgentX is a self-hosted, glassbox Cognitive OS for agents that reason, remember, and collaborate.',
      inputSchema: {
        type: 'object',
        properties: {
          query: { type: 'string', description: 'Natural-language search query.' },
        },
        required: ['query'],
      },
      async execute({ query }): Promise<ToolResult> {
        const q = String(query ?? '').trim();
        if (!q) return { content: [{ type: 'text', text: 'Provide a search query.' }] };
        const pf = await ensurePagefind();
        if (!pf) return { content: [{ type: 'text', text: 'Documentation search is unavailable.' }] };
        const { results } = await pf.search(q);
        if (!results.length) return { content: [{ type: 'text', text: `No documentation results for “${q}”.` }] };
        const data = await Promise.all(results.slice(0, 5).map((r) => r.data()));
        const text = data
          .map((d) => {
            const title = d.meta?.title ?? d.url;
            const url = new URL(d.url, location.origin).href;
            const excerpt = d.excerpt?.replace(/<[^>]+>/g, '').trim();
            return `- ${title} — ${url}${excerpt ? `\n  ${excerpt}` : ''}`;
          })
          .join('\n');
        return { content: [{ type: 'text', text }] };
      },
    };

    try {
      if (mc.provideContext) mc.provideContext({ tools: [searchDocs] });
      else mc.registerTool?.(searchDocs);
    } catch {
      /* WebMCP is experimental — never let tool registration break the page. */
    }
  }
</script>
