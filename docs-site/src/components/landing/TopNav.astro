---
import { site } from '../../config/site';
import { version } from '../../config/landing';
import Wordmark from '../ui/Wordmark.astro';
import MonoTag from '../ui/MonoTag.astro';
import GitHubGlyph from '../icons/GitHubGlyph.astro';
import ArrowRight from '../icons/ArrowRight.astro';

const repoSlug = site.repoUrl.replace('https://github.com/', '');
---

<header class="topnav">
  <div class="brand">
    <Wordmark size={32} />
    <span class="topnav-ver"><MonoTag>v{version} · alpha</MonoTag></span>
  </div>
  <nav class="actions">
    <a href={site.repoUrl} target="_blank" rel="noopener" class="gh">
      <GitHubGlyph />
      <span class="gh-label">{repoSlug}</span>
    </a>
    <a href={site.docsBasePath} class="docs-cta">
      Open the docs <ArrowRight size={14} />
    </a>
    <a href="/docs/getting-started/quickstart" class="nav-cta" data-nav-cta>
      Get started <ArrowRight size={14} />
    </a>
  </nav>
</header>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 48px;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-bg-2) 92%, transparent);
    backdrop-filter: blur(8px);
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }
  .topnav-ver {
    display: inline-flex;
    padding: 3px 8px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .gh {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 8px 12px;
    border-radius: 8px;
    border: 1px solid var(--color-border-2);
    color: var(--color-text);
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .gh:hover {
    color: var(--color-text-strong);
  }
  .docs-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
    padding: 8px 14px 8px 16px;
    border-radius: 8px;
    background: var(--color-accent);
    color: var(--color-accent-fg);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.005em;
    border: 1px solid var(--color-accent);
    box-shadow:
      0 0 0 1px color-mix(in oklab, var(--color-accent) 30%, transparent),
      0 6px 24px -8px color-mix(in oklab, var(--color-accent) 60%, transparent);
    transition: background 0.15s ease;
  }
  .docs-cta:hover {
    background: var(--color-accent-hover);
  }

  /* Scroll-aware "Get started" — the one gold accent in the chrome (action = energy).
     Hidden at the top; revealed once the hero scrolls away (see script). */
  .nav-cta {
    display: none;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    padding: 8px 14px 8px 16px;
    border-radius: 8px;
    background: linear-gradient(180deg, var(--c-energy-bright), var(--c-energy));
    color: #241803;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.005em;
    border: 1px solid color-mix(in oklab, var(--c-energy) 70%, #000);
    box-shadow: 0 4px 18px -6px color-mix(in oklab, var(--c-energy) 70%, transparent);
    transition: filter 0.15s ease;
  }
  .nav-cta[data-show='1'] {
    display: inline-flex;
    animation: nav-cta-in 0.28s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .nav-cta:hover {
    filter: brightness(1.06);
  }
  @keyframes nav-cta-in {
    from {
      opacity: 0;
      transform: translateX(8px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 720px) {
    .topnav {
      padding: 14px 18px;
    }
    /* On mobile the docs CTA yields to the scroll CTA to avoid crowding. */
    .docs-cta:has(~ .nav-cta[data-show='1']) {
      display: none;
    }
    .topnav-ver,
    .gh-label {
      display: none;
    }
    .actions {
      gap: 8px;
    }
    .gh {
      padding: 8px 10px;
    }
    .docs-cta {
      padding: 8px 12px;
      font-size: 13px;
    }
  }
</style>

<script>
  // Reveal the "Get started" CTA once the hero has largely scrolled away.
  const cta = document.querySelector<HTMLElement>('[data-nav-cta]');
  const hero = document.querySelector<HTMLElement>('.hero');
  if (cta && hero) {
    const io = new IntersectionObserver(
      ([e]) => {
        cta.dataset.show = e.isIntersecting ? '' : '1';
      },
      { threshold: 0, rootMargin: '-45% 0px 0px 0px' },
    );
    io.observe(hero);
  }
</script>
