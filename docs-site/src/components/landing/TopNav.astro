---
import { site } from '../../config/site';
import { version } from '../../config/landing';
import Wordmark from '../ui/Wordmark.astro';
import MonoTag from '../ui/MonoTag.astro';
import GitHubGlyph from '../icons/GitHubGlyph.astro';
import ArrowRight from '../icons/ArrowRight.astro';

const repoSlug = site.repoUrl.replace('https://github.com/', '');
---

<header class="topnav">
  <div class="brand">
    <Wordmark size={32} />
    <MonoTag class="topnav-version">v{version} · alpha</MonoTag>
  </div>
  <nav class="actions">
    <a href={site.repoUrl} target="_blank" rel="noopener" class="gh">
      <GitHubGlyph />
      <span class="gh-label">{repoSlug}</span>
    </a>
    <a href={site.docsBasePath} class="docs-cta">
      Open the docs <ArrowRight size={14} />
    </a>
  </nav>
</header>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 48px;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-bg-2) 92%, transparent);
    backdrop-filter: blur(8px);
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }
  .topnav-version {
    padding: 3px 8px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .gh {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 8px 12px;
    border-radius: 8px;
    border: 1px solid var(--color-border-2);
    color: var(--color-text);
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .gh:hover {
    color: var(--color-text-strong);
  }
  .docs-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px 8px 16px;
    border-radius: 8px;
    background: var(--color-accent);
    color: var(--color-accent-fg);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.005em;
    border: 1px solid var(--color-accent);
    box-shadow:
      0 0 0 1px color-mix(in oklab, var(--color-accent) 30%, transparent),
      0 6px 24px -8px color-mix(in oklab, var(--color-accent) 60%, transparent);
    transition: background 0.15s ease;
  }
  .docs-cta:hover {
    background: var(--color-accent-hover);
  }

  @media (max-width: 720px) {
    .topnav {
      padding: 14px 18px;
    }
    .topnav-version,
    .gh-label {
      display: none;
    }
    .actions {
      gap: 8px;
    }
    .gh {
      padding: 8px 10px;
    }
    .docs-cta {
      padding: 8px 12px;
      font-size: 13px;
    }
  }
</style>
