---
// The hero's living "glassbox" console: it replays a REAL recorded agent run
// (distilled into config/hero-run.json by scripts/distill-hero-run.mjs) — the lead
// recalls memory, delegates a work order to a teammate, who runs a tool and reports
// back, then the lead merges. Beats stream in on a snappy cadence with gold energy
// (the delegation packet rides the rail between agents); the displayed timestamps are
// the run's REAL relative times. prefers-reduced-motion → the whole run rendered static.
import run from '../../config/hero-run.json';
import MonoTag from '../ui/MonoTag.astro';

const roleColor: Record<string, string> = {
  lead: 'var(--c-agent)',
  researcher: 'var(--c-memory)',
  writer: 'var(--c-drafting)',
};
const colorFor = (role: string) => roleColor[role] ?? 'var(--c-agent)';

const roster = [
  { role: run.lead.role, id: run.lead.id, color: colorFor(run.lead.role) },
  ...run.team.map((t) => ({ role: t.role, id: t.id, color: colorFor(t.role) })),
];

const k = (n: number | null) =>
  n == null ? '' : n >= 1000 ? `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k` : String(n);
const s = run.stats;
---

<div class="console ax-glass" data-console>
  <div class="header-bar">
    <div class="header-left">
      <div class="lights"><span></span><span></span><span></span></div>
      <MonoTag class="run-label">AgX · run · {run.task}</MonoTag>
    </div>
    <span class="live" data-live>
      <span class="live-dot"></span>
      <MonoTag color="var(--color-ok)">live</MonoTag>
    </span>
  </div>

  <div class="run-progress"><span class="run-fill" data-progress></span></div>

  <div class="roster">
    <div class="roster-head">
      <span class="ax-mono roster-title-strong">AgX · team</span>
      <span class="ax-mono roster-title-dim">plan ⇢ delegate ⇢ merge</span>
    </div>
    <div class="roster-body">
      <div class="deleg-rail" aria-hidden="true">
        <span class="deleg-line"></span>
        <span class="deleg-packet" data-packet></span>
      </div>
      <div class="roster-rows">
        {
          roster.map((a) => (
            <div class="ax-alloy-row">
              <span class="alloy-role">
                <span class="alloy-dot" data-dot={a.role} style={`--c:${a.color}`} />
                <span style={`color:${a.color};font-weight:500`}>{a.role}</span>
              </span>
              <span class="alloy-id">@{a.id}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="body">
    <div class="ax-trace-header">
      <span class="ax-mono th">t</span>
      <span class="ax-mono th">agent</span>
      <span class="ax-mono th">kind</span>
      <span class="ax-mono th">event</span>
    </div>
    {
      run.beats.map((b) => (
        <div
          class="ax-trace-row"
          data-beat
          data-actor={b.actor}
          data-kind={b.kind}
          data-edge={b.edge ?? ''}
        >
          <span class="trace-t">+{b.t}s</span>
          <span class="trace-agent">
            <span class="trace-dot" style={`--c:${colorFor(b.actor)}`} />
            <span class="trace-role" style={`color:${colorFor(b.actor)}`}>
              {b.actor}
            </span>
          </span>
          <span class="trace-kind">{b.kind}</span>
          <span class="trace-event">
            <span class="beat-label">{b.label}</span>
            <span class="trace-msg">{b.detail}</span>
            <span class="beat-caret" aria-hidden="true">▍</span>
          </span>
        </div>
      ))
    }

    <div class="runline">
      <span class="run-dot"></span>
      <span class="ax-mono runline-stat">
        {s.model}{s.pattern ? ` · ${s.pattern}` : ''} · {k(s.tokensIn)}→{k(s.tokensOut)} tok
        {s.cost ? ` · ${s.cost}` : ''}
      </span>
    </div>
  </div>
</div>

<style>
  .console {
    padding: 0;
    overflow: hidden;
    box-shadow:
      0 30px 80px -30px rgba(0, 0, 0, 0.6),
      0 0 0 1px var(--color-border);
  }

  .header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-surface-2) 70%, transparent);
  }
  .header-left {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }
  .lights {
    display: flex;
    gap: 6px;
    flex: 0 0 auto;
  }
  .lights span {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #3a3f4b;
  }
  .run-label {
    margin-left: 8px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .live {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex: 0 0 auto;
  }
  .live-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-ok);
    box-shadow: 0 0 8px var(--color-ok);
    animation: ax-pulse 1.6s ease-in-out infinite;
  }

  /* Run progress — a thin gold fill driven by the playback script. */
  .run-progress {
    height: 2px;
    background: color-mix(in oklab, var(--c-energy) 14%, transparent);
    overflow: hidden;
  }
  .run-fill {
    display: block;
    height: 100%;
    transform-origin: left;
    transform: scaleX(0);
    background: linear-gradient(90deg, var(--c-energy-deep), var(--c-energy), var(--c-energy-bright));
    box-shadow: 0 0 10px color-mix(in oklab, var(--c-energy) 55%, transparent);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Roster */
  .roster {
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-surface) 80%, transparent);
  }
  .roster-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 12px;
  }
  .roster-title-strong {
    color: var(--color-text-strong);
    letter-spacing: 0.14em;
  }
  .roster-title-dim {
    color: var(--color-text-dim);
  }
  .roster-body {
    display: flex;
    gap: 10px;
  }
  /* Delegation rail — the gold packet rides between the two agent rows. */
  .deleg-rail {
    position: relative;
    flex: 0 0 12px;
    width: 12px;
  }
  .deleg-line {
    position: absolute;
    left: 50%;
    top: 16px;
    height: 38px;
    width: 1px;
    margin-left: -0.5px;
    background: linear-gradient(var(--c-energy), color-mix(in oklab, var(--c-energy) 20%, transparent));
    opacity: 0.28;
  }
  .deleg-packet {
    position: absolute;
    left: 50%;
    top: 0;
    width: 7px;
    height: 7px;
    margin-left: -3.5px;
    border-radius: 999px;
    background: radial-gradient(circle, var(--c-energy-core), var(--c-energy) 45%, transparent 72%);
    box-shadow: 0 0 9px 2px color-mix(in oklab, var(--c-energy) 60%, transparent);
    opacity: 0;
    transform: translateY(16px);
  }
  .deleg-packet.run[data-dir='down'] {
    animation: packet-down 0.72s ease-in-out;
  }
  .deleg-packet.run[data-dir='up'] {
    animation: packet-up 0.72s ease-in-out;
  }
  @keyframes packet-down {
    0% { transform: translateY(16px); opacity: 0; }
    12% { opacity: 1; }
    88% { opacity: 1; }
    100% { transform: translateY(54px); opacity: 0; }
  }
  @keyframes packet-up {
    0% { transform: translateY(54px); opacity: 0; }
    12% { opacity: 1; }
    88% { opacity: 1; }
    100% { transform: translateY(16px); opacity: 0; }
  }
  .roster-rows {
    flex: 1 1 auto;
    display: grid;
    gap: 6px;
    min-width: 0;
  }
  .ax-alloy-row {
    display: grid;
    grid-template-columns: 116px 1fr;
    gap: 12px;
    align-items: center;
    min-height: 32px;
    font-family: var(--font-mono);
    font-size: 12.5px;
  }
  .alloy-role {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .alloy-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--c);
    box-shadow: 0 0 6px var(--c);
    transition: box-shadow 0.25s ease;
  }
  .alloy-dot[data-pulse='1'] {
    box-shadow:
      0 0 0 3px color-mix(in oklab, var(--c-energy) 38%, transparent),
      0 0 12px var(--c-energy);
  }
  .alloy-id {
    color: var(--color-text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Trace body */
  .body {
    padding: 14px 16px 12px;
    background: var(--color-code-bg);
  }
  .ax-trace-header,
  .ax-trace-row {
    display: grid;
    grid-template-columns: 46px 116px 76px 1fr;
    gap: 12px;
  }
  .ax-trace-header {
    padding-bottom: 8px;
    margin-bottom: 6px;
    border-bottom: 1px dashed var(--color-border);
  }
  .th {
    color: var(--color-text-dim);
  }
  .ax-trace-row {
    align-items: baseline;
    padding: 7px 0;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.55;
    /* Streamed-in state (script drives data-state); static fallback below. */
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .ax-trace-row[data-state='shown'],
  .ax-trace-row[data-state='active'] {
    opacity: 1;
    transform: none;
  }
  .ax-trace-row[data-state='active'] .beat-label {
    color: var(--c-energy-bright);
    text-shadow: 0 0 10px color-mix(in oklab, var(--c-energy) 45%, transparent);
  }
  .trace-t {
    color: var(--color-text-dim);
  }
  .trace-agent {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-width: 0;
  }
  .trace-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--c);
    box-shadow: 0 0 6px var(--c);
    flex: 0 0 auto;
  }
  .trace-role {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .trace-kind {
    color: var(--color-text-muted);
    background: color-mix(in oklab, var(--color-surface-2) 90%, transparent);
    padding: 1px 7px;
    border-radius: 4px;
    font-size: 11.5px;
    display: inline-block;
    width: fit-content;
    letter-spacing: 0.02em;
    height: fit-content;
  }
  .beat-label {
    color: var(--color-text-strong);
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }
  .trace-msg {
    color: var(--color-text-muted);
    margin-left: 10px;
  }
  .beat-caret {
    display: none;
    color: var(--c-energy-bright);
    margin-left: 2px;
  }
  .ax-trace-row[data-state='active'] .beat-caret {
    display: inline;
    animation: caret-blink 0.8s step-end infinite;
  }
  @keyframes caret-blink {
    50% { opacity: 0; }
  }

  /* Footer stat line — the real run's numbers. */
  .runline {
    padding: 12px 0 2px;
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-top: 1px dashed var(--color-border);
  }
  .run-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--c-energy);
    box-shadow: 0 0 10px var(--c-energy);
    flex: 0 0 auto;
  }
  .runline-stat {
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }

  /* ≤720px — single-column stack */
  @media (max-width: 720px) {
    .ax-trace-header {
      display: none;
    }
    .ax-trace-row {
      grid-template-columns: 1fr;
      gap: 4px;
      padding: 8px 0;
      border-bottom: 1px dashed var(--color-border);
    }
    .trace-t,
    .trace-agent,
    .trace-kind {
      display: inline-flex;
      margin-right: 8px;
    }
    .trace-event {
      display: block;
      margin-top: 2px;
    }
    .trace-msg {
      margin-left: 0;
      display: block;
    }
    .ax-alloy-row {
      grid-template-columns: auto 1fr;
    }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-console]');
  if (root) {
    const rows = [...root.querySelectorAll<HTMLElement>('[data-beat]')];
    const dots = new Map(
      [...root.querySelectorAll<HTMLElement>('[data-dot]')].map((d) => [d.dataset.dot, d]),
    );
    const packet = root.querySelector<HTMLElement>('[data-packet]');
    const progress = root.querySelector<HTMLElement>('[data-progress]');
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));
    let token = 0; // bumped to cancel an in-flight run (scroll-out / restart)

    const setProgress = (v: number) => progress && (progress.style.transform = `scaleX(${v})`);

    function showStatic() {
      rows.forEach((r) => (r.dataset.state = 'shown'));
      setProgress(1);
    }

    function pulseDot(role?: string) {
      const d = role ? dots.get(role) : undefined;
      if (!d) return;
      d.dataset.pulse = '1';
      setTimeout(() => (d.dataset.pulse = ''), 700);
    }

    function flowEdge(to?: string) {
      if (!packet || !to) return;
      packet.dataset.dir = to === 'lead' ? 'up' : 'down';
      packet.classList.remove('run');
      void packet.offsetWidth; // reflow → restart the animation
      packet.classList.add('run');
    }

    async function play(mine: number) {
      rows.forEach((r) => (r.dataset.state = ''));
      setProgress(0);
      await wait(480);
      for (let i = 0; i < rows.length; i++) {
        if (mine !== token) return;
        const r = rows[i];
        r.dataset.state = 'active';
        setProgress((i + 1) / rows.length);
        pulseDot(r.dataset.actor);
        if (r.dataset.edge) flowEdge(r.dataset.edge);
        const emphatic = ['delegate', 'tool', 'report', 'merge'].includes(r.dataset.kind ?? '');
        await wait(emphatic ? 800 : 540);
        if (mine !== token) return;
        r.dataset.state = 'shown';
      }
      await wait(2800);
      if (mine === token) play(mine); // loop
    }

    if (reduce) {
      showStatic();
    } else {
      // Play only while visible — restart on re-entry, cancel when scrolled away.
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            token++;
            if (e.isIntersecting) play(token);
          }
        },
        { threshold: 0.25 },
      );
      io.observe(root);
    }
  }
</script>
