---
import { HERO_STATS, version } from '../../config/landing';
import { site } from '../../config/site';
import MonoTag from '../ui/MonoTag.astro';
import Cta from '../ui/Cta.astro';
import ArrowRight from '../icons/ArrowRight.astro';
import GitHubGlyph from '../icons/GitHubGlyph.astro';
import TraceConsole from './TraceConsole.astro';
import CosmicField from './CosmicField.astro';
import QuickstartChip from './QuickstartChip.astro';
---

<section class="hero">
  <CosmicField intensity="hero" />

  <div class="hero-grid">
    {/* LEFT — type column */}
    <div class="type">
      <div class="eyebrow">
        <img src="/AgentX-Logo-v4.png" alt="" width="56" height="56" class="eyebrow-badge" />
        <div>
          <MonoTag>self-hosted · glassbox · open</MonoTag>
          <div class="ax-mono version">v{version} · alpha</div>
        </div>
      </div>

      <h1 class="ax-wordmark hero-wordmark">AgentX</h1>

      <h2 class="tagline">
        The Cognitive OS for agents that<br />
        <span class="tagline-muted">
          reason, remember &amp; <span class="tagline-accent">collaborate</span>.
        </span>
      </h2>

      <p class="lede">
        A self-hosted platform you can see inside. Six thinking patterns, four memory
        types that persist and learn, teams of agents that delegate to each other, and any
        model you bring — with every decision the loop makes streamed live.
      </p>

      <div class="cta-row">
        <Cta kind="solid" href="/docs/getting-started/quickstart">
          Get started
          <ArrowRight slot="icon" />
        </Cta>
        <Cta kind="ghost" href={site.repoUrl}>
          Star on GitHub
          <GitHubGlyph slot="icon" />
        </Cta>
      </div>

      <QuickstartChip />

      <div class="stats">
        {
          HERO_STATS.map((s) => (
            <div>
              <MonoTag color="var(--color-text-dim)">{s.l}</MonoTag>
              <div class="stat-v">{s.v}</div>
            </div>
          ))
        }
      </div>
    </div>

    {/* RIGHT — trace console */}
    <TraceConsole />
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 72px 48px 64px;
    overflow: hidden;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: 56px;
    align-items: center;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 24px;
  }
  .eyebrow-badge {
    border-radius: 12px;
  }
  .version {
    margin-top: 4px;
    color: var(--c-memory);
  }

  .hero-wordmark {
    font-size: clamp(64px, 11vw, 132px);
    font-weight: 800;
    line-height: 0.92;
    margin: 0 0 4px;
  }

  .tagline {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.4vw, 36px);
    font-weight: 500;
    letter-spacing: -0.025em;
    color: var(--color-text-strong);
    margin: 12px 0 18px;
    line-height: 1.15;
    text-wrap: pretty;
  }
  .tagline-muted {
    color: var(--color-text-muted);
  }
  .tagline-accent {
    color: var(--c-reasoning);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--c-reasoning) 50%, transparent);
    text-underline-offset: 6px;
    text-decoration-thickness: 2px;
  }

  .lede {
    font-size: 16px;
    color: var(--color-text-muted);
    max-width: 540px;
    line-height: 1.6;
    margin: 0 0 28px;
  }

  .cta-row {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 16px;
  }

  .stats {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }
  .stat-v {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text);
    margin-top: 4px;
  }

  @media (max-width: 1024px) {
    .hero {
      padding: 56px 32px;
    }
    .hero-grid {
      /* minmax(0,1fr) — not bare 1fr — so the track can shrink below the
         quickstart chip's nowrap command line instead of overflowing the hero. */
      grid-template-columns: minmax(0, 1fr);
      gap: 36px;
    }
  }
  @media (max-width: 720px) {
    .hero {
      padding: 36px 18px 40px;
    }
    .hero-grid {
      gap: 28px;
    }
    .lede {
      font-size: 15px;
    }
    .cta-row {
      flex-wrap: wrap;
    }
    .deploy-pill {
      flex-wrap: wrap;
    }
    .stats {
      gap: 16px 22px;
    }
  }
</style>
