---
// "Why AgentX" — three conversion pillars (It thinks · works as a team · is yours),
// each a titled segment with its supporting cards. Data from config/landing.ts.
import { PILLARS } from '../../config/landing';
import MonoTag from '../ui/MonoTag.astro';
import Dot from '../ui/Dot.astro';
import ArrowRight from '../icons/ArrowRight.astro';
---

<section class="why">
  <div class="inner">
    <div class="head">
      <h2 class="ax-wordmark title">Why AgentX</h2>
      <MonoTag>§ what makes it different</MonoTag>
    </div>

    <div class="pillars">
      {
        PILLARS.map((p) => (
          <div class="pillar" style={`--accent:${p.color}`}>
            <div class="pillar-head">
              <div class="pillar-name">
                <Dot color={p.color} size={8} />
                <h3 class="ax-wordmark pname">{p.name}</h3>
              </div>
              <p class="plede">{p.lede}</p>
            </div>

            <div class="grid">
              {p.cards.map((d) => (
                <a class="card ax-glass ax-lift" href={d.href} style={`--accent:${d.color}`}>
                  <div class="card-top">
                    <Dot color={d.color} size={7} />
                    <MonoTag color={d.color}>{d.tag}</MonoTag>
                  </div>
                  <h4 class="card-title">{d.title}</h4>
                  <p class="card-desc">{d.desc}</p>
                  <span class="card-more">
                    Learn more <ArrowRight size={12} />
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .why {
    padding: 16px 48px 24px;
  }
  .inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 30px;
  }
  .title {
    font-size: 32px;
    margin: 0;
    font-weight: 600;
  }

  .pillars {
    display: grid;
    gap: 44px;
  }
  .pillar-head {
    display: flex;
    align-items: baseline;
    gap: 22px;
    flex-wrap: wrap;
    padding-bottom: 16px;
    margin-bottom: 18px;
    border-bottom: 1px solid var(--color-border);
  }
  .pillar-name {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 0 0 auto;
  }
  .pname {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text-strong);
    margin: 0;
  }
  .plede {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-text-muted);
    max-width: 660px;
    text-wrap: pretty;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 22px;
    border-radius: var(--radius-card);
    color: var(--color-text);
    border-top: 2px solid color-mix(in oklab, var(--accent) 55%, transparent);
  }
  .card-top {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-text-strong);
    margin: 0;
  }
  .card-desc {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--color-text-muted);
    text-wrap: pretty;
  }
  .card-more {
    margin-top: auto;
    padding-top: 6px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-dim);
    transition: color 0.15s ease;
  }
  .card:hover .card-more {
    color: var(--accent);
  }
  /* Hover lifts the card into its own accent light. */
  .card:hover {
    border-top-color: color-mix(in oklab, var(--accent) 85%, transparent);
    box-shadow:
      0 18px 46px -22px rgba(0, 0, 0, 0.85),
      0 0 0 1px color-mix(in oklab, var(--accent) 28%, transparent),
      0 10px 40px -18px color-mix(in oklab, var(--accent) 30%, transparent);
  }

  @media (max-width: 980px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 720px) {
    .why {
      padding: 8px 18px 16px;
    }
    .pillars {
      gap: 34px;
    }
    .pillar-head {
      flex-direction: column;
      gap: 8px;
    }
    .grid {
      grid-template-columns: 1fr;
    }
    .card {
      padding: 18px;
    }
    .title {
      font-size: 24px;
    }
  }
</style>
