---
import SidebarLink from './SidebarLink.astro';
import type { NavLink } from '../../config/nav';

interface Props {
  label: string;
  items: NavLink[];
  currentSlug: string;
}

const { label, items, currentSlug } = Astro.props;
---

<div class="mt-5 first:mt-0">
  <p class="px-3 pb-1 text-xs font-semibold tracking-wide text-text-muted uppercase">
    {label}
  </p>
  <div class="flex flex-col gap-0.5">
    {items.map((item) => <SidebarLink label={item.label} slug={item.slug} currentSlug={currentSlug} />)}
  </div>
</div>
