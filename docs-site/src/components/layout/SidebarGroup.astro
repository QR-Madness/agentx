---
import SidebarLink from './SidebarLink.astro';
import type { NavLink } from '../../config/nav';

interface Props {
  label: string;
  items: NavLink[];
  currentSlug: string;
}

const { label, items, currentSlug } = Astro.props;
---

<div class="group">
  <p class="ax-mono group-label">{label}</p>
  <div class="group-items">
    {
      items.map((item) => (
        <SidebarLink
          label={item.label}
          slug={item.slug}
          currentSlug={currentSlug}
          color={item.color}
        />
      ))
    }
  </div>
</div>

<style>
  .group {
    margin-bottom: 18px;
  }
  .group-label {
    padding: 6px 14px;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    color: var(--color-text-dim);
  }
  .group-items {
    display: grid;
    gap: 1px;
    margin-top: 4px;
  }
</style>
