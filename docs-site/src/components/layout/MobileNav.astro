---
import Sidebar from './Sidebar.astro';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
---

<details class="border-b border-border lg:hidden">
  <summary class="cursor-pointer list-none px-4 py-3 text-sm font-medium text-text-muted">
    Menu
  </summary>
  <div class="px-2 pb-4">
    <Sidebar currentSlug={currentSlug} />
  </div>
</details>
