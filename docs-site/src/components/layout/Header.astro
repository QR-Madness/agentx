---
import { site } from '../../config/site';
---

<header class="sticky top-0 z-30 border-b border-border bg-bg/80 backdrop-blur">
  <div class="mx-auto flex h-14 max-w-[88rem] items-center gap-4 px-4">
    <a href="/" class="font-semibold text-text">{site.name}</a>
    <nav class="ml-auto flex items-center gap-5 text-sm text-text-muted">
      <a href="/docs" class="hover:text-text">Docs</a>
      <a href={site.repoUrl} target="_blank" rel="noopener" class="hover:text-text">GitHub</a>
    </nav>
  </div>
</header>
