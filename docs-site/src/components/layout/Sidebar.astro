---
import { nav, isGroup } from '../../config/nav';
import { site } from '../../config/site';
import SidebarGroup from './SidebarGroup.astro';
import SidebarLink from './SidebarLink.astro';
import Search from './Search.astro';
import GitHubGlyph from '../icons/GitHubGlyph.astro';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const repoSlug = site.repoUrl.replace('https://github.com/', '');
---

<aside class="ax-docs-sidebar ax-scroll" data-docs-sidebar data-open="false">
  <button type="button" class="ax-docs-sidebar-close" data-drawer-close aria-label="Close navigation">
    ✕
  </button>

  {/* Brand + back-to-home */}
  <a href="/" class="brand">
    <img src="/AgentX-Logo-v3-badge.png" alt="" width="28" height="28" class="brand-badge" />
    <span class="brand-text">
      <span class="brand-name">AgentX</span>
      <span class="ax-mono brand-sub">← back to home</span>
    </span>
  </a>

  {/* GitHub repo link */}
  <a href={site.repoUrl} target="_blank" rel="noopener" class="repo-pill">
    <GitHubGlyph size={13} />
    <span class="repo-name">{repoSlug}</span>
    <span class="repo-arrow">↗</span>
  </a>

  <div class="search-slot">
    <Search />
  </div>

  <nav aria-label="Documentation" class="nav">
    {
      nav.map((entry) =>
        isGroup(entry) ? (
          <SidebarGroup label={entry.label} items={entry.items} currentSlug={currentSlug} />
        ) : (
          <div class="top-link">
            <SidebarLink label={entry.label} slug={entry.slug} currentSlug={currentSlug} />
          </div>
        )
      )
    }
  </nav>
</aside>

<style>
  .ax-docs-sidebar {
    width: var(--layout-sidebar-width);
    flex: 0 0 var(--layout-sidebar-width);
    border-right: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-bg) 50%, var(--color-bg-2));
    position: sticky;
    top: 0;
    align-self: flex-start;
    height: 100vh;
    overflow-y: auto;
    padding: 20px 16px 48px;
    display: flex;
    flex-direction: column;
  }

  .ax-docs-sidebar-close {
    position: absolute;
    top: 12px;
    right: 12px;
    appearance: none;
    background: transparent;
    border: 1px solid var(--color-border-2);
    border-radius: 6px;
    padding: 4px 8px;
    color: var(--color-text-muted);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 10px;
    margin-bottom: 12px;
    border-radius: 8px;
    color: var(--color-text);
    transition: background 0.15s ease;
  }
  .brand:hover {
    background: color-mix(in oklab, var(--color-surface) 70%, transparent);
  }
  .brand-badge {
    flex: 0 0 auto;
    border-radius: 7px;
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .brand-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text-strong);
    line-height: 1.1;
  }
  .brand-sub {
    color: var(--color-text-dim);
    font-size: 9.5px;
    margin-top: 2px;
  }

  .repo-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 12px;
    margin-bottom: 16px;
    border: 1px solid var(--color-border-2);
    border-radius: 8px;
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 11.5px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .repo-pill:hover {
    color: var(--color-text);
    border-color: var(--color-border-2);
  }
  .repo-name {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .repo-arrow {
    color: var(--color-text-dim);
  }

  .search-slot {
    margin-bottom: 20px;
  }

  .nav {
    display: flex;
    flex-direction: column;
  }
  .top-link {
    margin-bottom: 4px;
  }
</style>

<script>
  // Scroll the active nav item into view *within the sidebar* (never the window),
  // so deep pages don't open with their entry hidden below the fold.
  const sidebar = document.querySelector<HTMLElement>('[data-docs-sidebar]');
  const active = sidebar?.querySelector<HTMLElement>('[aria-current="page"]');
  if (sidebar && active) {
    const s = sidebar.getBoundingClientRect();
    const a = active.getBoundingClientRect();
    const delta = a.top - s.top - (sidebar.clientHeight / 2 - a.height / 2);
    sidebar.scrollTop += delta; // browser clamps to [0, maxScroll]
  }
</script>
