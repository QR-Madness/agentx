---
import { site } from '../../config/site';
---

<footer class="border-t border-border px-4 py-6 text-sm text-text-muted">
  <div class="mx-auto flex max-w-[88rem] flex-wrap items-center gap-x-4 gap-y-1">
    <span>{site.copyright}</span>
    <a class="ml-auto hover:text-text" href={site.repoUrl} target="_blank" rel="noopener">
      {site.repoName}
    </a>
  </div>
</footer>
