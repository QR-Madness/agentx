# =============================================================================
# AgentX Production Configuration
# =============================================================================
# Copy this file to .env.production and fill in the values.
# For production deployment with Docker Compose and Cloudflare Tunnel.

# -----------------------------------------------------------------------------
# Cluster Identity (REQUIRED for multi-cluster)
# -----------------------------------------------------------------------------

# Unique name for this cluster (used in container names, logs, health endpoint)
AGENTX_CLUSTER_NAME=production

# Port configuration (change these for each cluster to avoid conflicts)
API_PORT=12319
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
POSTGRES_PORT=5432
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Django Settings (REQUIRED)
# -----------------------------------------------------------------------------

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Set to false for production
DJANGO_DEBUG=false

# Your domain(s) - comma-separated. Include your Cloudflare Tunnel domain.
# Example: agentx.yourdomain.com,localhost
DJANGO_ALLOWED_HOSTS=

# -----------------------------------------------------------------------------
# Database Credentials (REQUIRED - change from defaults!)
# -----------------------------------------------------------------------------

NEO4J_PASSWORD=
POSTGRES_USER=agent
POSTGRES_PASSWORD=
POSTGRES_DB=agent_memory

# -----------------------------------------------------------------------------
# Authentication (REQUIRED for production)
# -----------------------------------------------------------------------------

# Enable authentication (required for internet-exposed deployments)
AGENTX_AUTH_ENABLED=true

# Session TTL in seconds (default: 86400 = 24 hours)
AGENTX_SESSION_TTL=86400

# -----------------------------------------------------------------------------
# CORS/CSRF for Cloudflare Tunnel (REQUIRED for production)
# -----------------------------------------------------------------------------

# Allowed origins for CORS - your Cloudflare Tunnel URL(s)
# Example: https://agentx.yourdomain.com
CORS_ALLOWED_ORIGINS=

# Trusted origins for CSRF - same as CORS
# Example: https://agentx.yourdomain.com
CSRF_TRUSTED_ORIGINS=

# -----------------------------------------------------------------------------
# LLM Provider API Keys (at least one required)
# -----------------------------------------------------------------------------

# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=

# OpenAI API key (for GPT models)
OPENAI_API_KEY=

# OpenRouter API key (for 100+ models via single API)
OPENROUTER_API_KEY=

# Vercel AI Gateway (cloud aggregator - 100+ models, high availability)
# Get your key at: https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------

# Embedding provider: "local" (uses BAAI/bge-m3) or "openai"
EMBEDDING_PROVIDER=local

# -----------------------------------------------------------------------------
# Deployment Notes
# -----------------------------------------------------------------------------
#
# Single Cluster Deployment:
#   1. Copy this file to .env.production in your cluster directory
#   2. Generate a strong DJANGO_SECRET_KEY
#   3. Change all default passwords (NEO4J_PASSWORD, POSTGRES_PASSWORD)
#   4. Run: docker compose --profile production up -d
#   5. Set up auth: docker compose exec api uv run manage.py setup_auth
#   6. Configure Cloudflare Tunnel to point to your server
#
# Multi-Cluster Deployment:
#   1. Create a directory for each cluster (e.g., ~/clusters/prod, ~/clusters/staging)
#   2. Copy this file to <cluster-dir>/.env.production
#   3. Set unique AGENTX_CLUSTER_NAME and ports for each cluster
#   4. Use the launcher script: ./scripts/agentx-cluster ~/clusters/prod up -d
#   5. Each cluster will have isolated data in <cluster-dir>/data/
#
# Example port allocation for two clusters:
#   Cluster 1 (production): API=12319, NEO4J=7474/7687, POSTGRES=5432, REDIS=6379
#   Cluster 2 (staging):    API=12320, NEO4J=7475/7688, POSTGRES=5433, REDIS=6380
