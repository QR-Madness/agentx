# =============================================================================
# AgentX Production Configuration
# =============================================================================
# Copy this file to .env.production and fill in the values.
# For production deployment with Docker Compose and Cloudflare Tunnel.

# -----------------------------------------------------------------------------
# Django Settings (REQUIRED)
# -----------------------------------------------------------------------------

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Set to false for production
DJANGO_DEBUG=false

# Your domain(s) - comma-separated. Include your Cloudflare Tunnel domain.
# Example: agentx.yourdomain.com,localhost
DJANGO_ALLOWED_HOSTS=

# -----------------------------------------------------------------------------
# Database Credentials (REQUIRED - change from defaults!)
# -----------------------------------------------------------------------------

NEO4J_PASSWORD=
POSTGRES_USER=agent
POSTGRES_PASSWORD=
POSTGRES_DB=agent_memory

# -----------------------------------------------------------------------------
# Authentication (REQUIRED for production)
# -----------------------------------------------------------------------------

# Enable authentication (required for internet-exposed deployments)
AGENTX_AUTH_ENABLED=true

# Session TTL in seconds (default: 86400 = 24 hours)
AGENTX_SESSION_TTL=86400

# -----------------------------------------------------------------------------
# CORS/CSRF for Cloudflare Tunnel (REQUIRED for production)
# -----------------------------------------------------------------------------

# Allowed origins for CORS - your Cloudflare Tunnel URL(s)
# Example: https://agentx.yourdomain.com
CORS_ALLOWED_ORIGINS=

# Trusted origins for CSRF - same as CORS
# Example: https://agentx.yourdomain.com
CSRF_TRUSTED_ORIGINS=

# -----------------------------------------------------------------------------
# LLM Provider API Keys (at least one required)
# -----------------------------------------------------------------------------

# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=

# OpenAI API key (for GPT models)
OPENAI_API_KEY=

# OpenRouter API key (for 100+ models via single API)
OPENROUTER_API_KEY=

# Vercel AI Gateway (cloud aggregator - 100+ models, high availability)
# Get your key at: https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------

# Embedding provider: "local" (uses BAAI/bge-m3) or "openai"
EMBEDDING_PROVIDER=local

# -----------------------------------------------------------------------------
# Deployment Notes
# -----------------------------------------------------------------------------
#
# 1. Generate a strong DJANGO_SECRET_KEY before deployment
# 2. Change all default passwords (NEO4J_PASSWORD, POSTGRES_PASSWORD)
# 3. Set up root password with: docker compose exec api uv run manage.py setup_auth
# 4. Configure Cloudflare Tunnel to point to your server on port 12319
# 5. Add your tunnel domain to DJANGO_ALLOWED_HOSTS, CORS_ALLOWED_ORIGINS, CSRF_TRUSTED_ORIGINS
#
# Start production stack:
#   docker compose --profile production up -d
#
# View logs:
#   docker compose logs -f api
#
# Set up authentication:
#   docker compose exec api uv run manage.py setup_auth
