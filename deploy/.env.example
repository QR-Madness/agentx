# =============================================================================
# AgentX — Isolated deployment configuration
# =============================================================================
# Copy this file to `.env` and fill in the required values, then start with:
#   docker compose up -d
#
# This is a self-contained ("isolated") deployment: it pulls the published API
# image and runs its own Neo4j + PostgreSQL + Redis. No repo or Taskfile needed
# — day-2 operations run through the in-image CLI:
#   docker compose exec api agentx help

# -----------------------------------------------------------------------------
# Deployment plumbing
# -----------------------------------------------------------------------------

# Which services a plain `docker compose up -d` brings up:
#   production — the API + databases
#   manager    — the web deployment manager (dashboard on http://127.0.0.1:12320;
#                loopback-only + token-gated). Remove it from the list if you
#                prefer to run without the dashboard.
COMPOSE_PROFILES=production,manager

# Published API image. Pin to a specific version for reproducible deploys
# (recommended) instead of :latest.
AGENTX_IMAGE=qrmadness/agentx-api:latest

# Instance name (used in container names, logs, the health endpoint).
AGENTX_CLUSTER_NAME=agentx

# Where config + database storage live, relative to this file. The HuggingFace
# model cache also lives under AGENTX_DB_DIR (hf-cache/), so models persist
# across container recreates.
AGENTX_CONFIG_DIR=./data
AGENTX_DB_DIR=./data

# Host ports.
API_PORT=12319
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
POSTGRES_PORT=5432
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Django (REQUIRED)
# -----------------------------------------------------------------------------

# Generate with:
#   docker run --rm python:3.12-slim python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

DJANGO_DEBUG=false

# Comma-separated hosts/IPs you'll reach the API on (localhost/127.0.0.1 are
# always allowed). E.g. your LAN IP or hostname.
DJANGO_ALLOWED_HOSTS=

# -----------------------------------------------------------------------------
# Database credentials (REQUIRED — change from defaults)
# -----------------------------------------------------------------------------

NEO4J_PASSWORD=
POSTGRES_USER=agent
POSTGRES_PASSWORD=
POSTGRES_DB=agent_memory

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Strongly recommended for any networked deployment. On first start with this
# enabled and no password set, run:  docker compose exec api agentx setup-auth
AGENTX_AUTH_ENABLED=true
AGENTX_SESSION_TTL=86400

# -----------------------------------------------------------------------------
# Public access (optional) — Gateway + Cloudflare Tunnel
# -----------------------------------------------------------------------------
# To go public, front the API with the bundled Nginx gateway (shared-secret
# header + rate limiting) and expose it via a Cloudflare Tunnel or your own
# reverse proxy — see the self-hosting guide's "Going public" section and the
# README's copy-paste path. Quick reference:
#
#   1. mkdir -p gateway && cp gateway/nginx.conf.example gateway/nginx.conf
#   2. Generate the shared secret:  openssl rand -hex 32
#   3. Layer docker-compose.gateway.yml plus ONE exposure overlay:
#      - docker-compose.tunnel.yml        dashboard token tunnel; set the
#                                         Public Hostname Service to
#                                         http://nginx:80
#      - docker-compose.tunnel.named.yml  credentials-file named tunnel
#      - docker-compose.gateway.expose.yml  host port for your own proxy/TLS

# Public hostname (extends ALLOWED_HOSTS / CORS / CSRF in one shot).
#   AGENTX_PUBLIC_HOST=agentx.example.com

# Connector token for the dashboard-managed tunnel (docker-compose.tunnel.yml).
#   TUNNEL_TOKEN=

# Shared secret the gateway requires in the AgentX-Gateway-Token header on
# every request. Generate with: openssl rand -hex 32
#   AGENTX_GATEWAY_TOKEN=

# Where the gateway files live (nginx.conf, cloudflared/). Default ./gateway.
#   AGENTX_GATEWAY_DIR=./gateway

# Trust X-Forwarded-For for client-IP attribution. Set true when the gateway
# fronts the API (nginx overwrites the header with the real client IP); leave
# unset/false when the API is reached directly.
#   AGENTX_TRUST_PROXY=true

# Gateway-only exposure (docker-compose.gateway.expose.yml) bind + port.
#   AGENTX_GATEWAY_BIND=127.0.0.1
#   AGENTX_GATEWAY_PORT=8080

# -----------------------------------------------------------------------------
# Schema auto-init
# -----------------------------------------------------------------------------

# The API self-initializes its database schemas on first boot (idempotent).
# Set to false to manage migrations manually via `agentx migrate`.
AGENTX_AUTO_INIT=true

# -----------------------------------------------------------------------------
# Compute device (optional)
# -----------------------------------------------------------------------------

# auto | cpu | cuda | cuda:N. "auto" uses CUDA when available. For GPU, also
# layer the GPU overlay: docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d
AGENTX_DEVICE=auto

# -----------------------------------------------------------------------------
# LLM provider API keys (at least one required)
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
AI_GATEWAY_API_KEY=

# "local" (BAAI/bge-m3, runs in-container) or "openai"
EMBEDDING_PROVIDER=local
