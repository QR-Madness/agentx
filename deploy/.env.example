# =============================================================================
# AgentX — Isolated deployment configuration
# =============================================================================
# Copy this file to `.env` and fill in the required values, then start with:
#   docker compose up -d
#
# This is a self-contained ("isolated") deployment: it pulls the published API
# image and runs its own Neo4j + PostgreSQL + Redis. No repo or Taskfile needed
# — day-2 operations run through the in-image CLI:
#   docker compose exec api agentx help

# -----------------------------------------------------------------------------
# Deployment plumbing
# -----------------------------------------------------------------------------

# Start the API service (it is gated behind the `production` compose profile).
# Leaving this set means a plain `docker compose up -d` brings up the API.
COMPOSE_PROFILES=production

# Published API image. Pin to a specific version for reproducible deploys
# (recommended) instead of :latest.
AGENTX_IMAGE=qrmadness/agentx-api:latest

# Instance name (used in container names, logs, the health endpoint).
AGENTX_CLUSTER_NAME=agentx

# Where config + database storage live, relative to this file. The HuggingFace
# model cache also lives under AGENTX_DB_DIR (hf-cache/), so models persist
# across container recreates.
AGENTX_CONFIG_DIR=./data
AGENTX_DB_DIR=./data

# Host ports.
API_PORT=12319
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
POSTGRES_PORT=5432
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Django (REQUIRED)
# -----------------------------------------------------------------------------

# Generate with:
#   docker run --rm python:3.12-slim python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

DJANGO_DEBUG=false

# Comma-separated hosts/IPs you'll reach the API on (localhost/127.0.0.1 are
# always allowed). E.g. your LAN IP or hostname.
DJANGO_ALLOWED_HOSTS=

# -----------------------------------------------------------------------------
# Database credentials (REQUIRED — change from defaults)
# -----------------------------------------------------------------------------

NEO4J_PASSWORD=
POSTGRES_USER=agent
POSTGRES_PASSWORD=
POSTGRES_DB=agent_memory

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Strongly recommended for any networked deployment. On first start with this
# enabled and no password set, run:  docker compose exec api agentx setup-auth
AGENTX_AUTH_ENABLED=true
AGENTX_SESSION_TTL=86400

# -----------------------------------------------------------------------------
# Public access (optional) — Cloudflare Tunnel
# -----------------------------------------------------------------------------
# To reach this instance over the internet via a dashboard-managed Cloudflare
# Tunnel running as a container (no cloudflared on the host, no inbound ports),
# see the self-hosting guide's "Going public" section. Set the public hostname
# below (extends ALLOWED_HOSTS / CORS / CSRF), and put the tunnel's connector
# token here so the docker-compose.tunnel.yml overlay can pick it up.
#   AGENTX_PUBLIC_HOST=agentx.example.com
#   TUNNEL_TOKEN=

# -----------------------------------------------------------------------------
# Schema auto-init
# -----------------------------------------------------------------------------

# The API self-initializes its database schemas on first boot (idempotent).
# Set to false to manage migrations manually via `agentx migrate`.
AGENTX_AUTO_INIT=true

# -----------------------------------------------------------------------------
# Compute device (optional)
# -----------------------------------------------------------------------------

# auto | cpu | cuda | cuda:N. "auto" uses CUDA when available. For GPU, also
# layer the GPU overlay: docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d
AGENTX_DEVICE=auto

# -----------------------------------------------------------------------------
# LLM provider API keys (at least one required)
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
AI_GATEWAY_API_KEY=

# "local" (BAAI/bge-m3, runs in-container) or "openai"
EMBEDDING_PROVIDER=local
